<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Outer border -->
    <solid android:color="#E3F2FD" />  <!-- Very light blue background -->
    <stroke
        android:width="1dp"
        android:color="#2196F3" />       <!-- Blue border -->

    <!-- Rounded corners -->
    <corners android:radius="8dp" />

    <!-- Padding inside the shape -->
    <padding
        android:left="0dp"
        android:top="6dp"
        android:right="0dp"
        android:bottom="6dp" />
</shape>
