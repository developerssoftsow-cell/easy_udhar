<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/dialog_background">


    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Filter Customers"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:gravity="center"
        android:layout_marginBottom="20dp" />


    <RadioGroup
        android:id="@+id/radioFilterGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">


        <LinearLayout
            android:id="@+id/layoutAll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp"
            android:clickable="true"
            android:focusable="true">

            <RadioButton
                android:id="@+id/radioAll"
                android:layout_width="26dp"
                android:layout_height="25dp"
                android:checked="true" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="All Customers"
                android:textSize="16sp"
                android:textColor="@color/black"
                android:layout_marginStart="12dp" />
        </LinearLayout>


        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/seperator"
            android:layout_marginVertical="8dp" />

        <LinearLayout
            android:id="@+id/layoutAmountAsc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp"
            android:clickable="true"
            android:focusable="true">

            <RadioButton
                android:id="@+id/radioAmountAsc"
                android:layout_width="26dp"
                android:layout_height="25dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Amount (Low to High)"
                android:textSize="16sp"
                android:textColor="@color/black"
                android:layout_marginStart="12dp" />
        </LinearLayout>


        <LinearLayout
            android:id="@+id/layoutAmountDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp"
            android:clickable="true"
            android:focusable="true">

            <RadioButton
                android:id="@+id/radioAmountDesc"
                android:layout_width="26dp"
                android:layout_height="25dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Amount (High to Low)"
                android:textSize="16sp"
                android:textColor="@color/black"
                android:layout_marginStart="12dp" />
        </LinearLayout>


        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/seperator"
            android:layout_marginVertical="8dp" />


        <LinearLayout
            android:id="@+id/layoutNameAsc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp"
            android:clickable="true"
            android:focusable="true">

            <RadioButton
                android:id="@+id/radioNameAsc"
                android:layout_width="26dp"
                android:layout_height="25dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Name (A to Z)"
                android:textSize="16sp"
                android:textColor="@color/black"
                android:layout_marginStart="12dp" />
        </LinearLayout>


        <LinearLayout
            android:id="@+id/layoutNameDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp"
            android:clickable="true"
            android:focusable="true">

            <RadioButton
                android:id="@+id/radioNameDesc"
                android:layout_width="26dp"
                android:layout_height="25dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Name (Z to A)"
                android:textSize="16sp"
                android:textColor="@color/black"
                android:layout_marginStart="12dp" />
        </LinearLayout>


        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/seperator"
            android:layout_marginVertical="8dp" />


        <LinearLayout
            android:id="@+id/layoutNumeric"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp"
            android:clickable="true"
            android:focusable="true">

            <RadioButton
                android:id="@+id/radioNumeric"
                android:layout_width="26dp"
                android:layout_height="25dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Numeric Names Only"
                android:textSize="16sp"
                android:textColor="@color/black"
                android:layout_marginStart="12dp" />
        </LinearLayout>

    </RadioGroup>


    <Button
        android:id="@+id/btnApplyFilter"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Apply Filter"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textColor="@color/white"
        android:background="@drawable/black_rounded_btn"
        android:layout_marginTop="20dp" />

</LinearLayout>