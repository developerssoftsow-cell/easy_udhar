<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter 4-digit PIN"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginBottom="20dp"
        android:layout_gravity="center"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="center"
        android:layout_marginBottom="30dp">

        <EditText
            android:id="@+id/etPin1"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:maxLength="1"
            android:inputType="number"
            android:gravity="center"
            android:textSize="20sp"
            android:background="@drawable/pin_box_bg"
            android:textStyle="bold"/>

        <EditText
            android:id="@+id/etPin2"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginStart="12dp"
            android:maxLength="1"
            android:inputType="number"
            android:gravity="center"
            android:textSize="20sp"
            android:background="@drawable/pin_box_bg"
            android:textStyle="bold"/>

        <EditText
            android:id="@+id/etPin3"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginStart="12dp"
            android:maxLength="1"
            android:inputType="number"
            android:gravity="center"
            android:textSize="20sp"
            android:background="@drawable/pin_box_bg"
            android:textStyle="bold"/>

        <EditText
            android:id="@+id/etPin4"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginStart="12dp"
            android:maxLength="1"
            android:inputType="number"
            android:gravity="center"
            android:textSize="20sp"
            android:background="@drawable/pin_box_bg"
            android:textStyle="bold"/>

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="This PIN will be required to open the app"
        android:textSize="12sp"
        android:textColor="#666666"
        android:layout_gravity="center"
        android:layout_marginBottom="20dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Cancel"
            android:backgroundTint="#9E9E9E"
            android:textColor="#FFFFFF"
            android:padding="12dp"/>

        <Button
            android:id="@+id/btnConfirm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Confirm"
            android:backgroundTint="#AD9980"
            android:textColor="#FFFFFF"
            android:padding="12dp"/>

    </LinearLayout>

</LinearLayout>