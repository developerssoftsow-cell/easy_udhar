<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    app:cardCornerRadius="12dp"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">


            <TextView
                android:id="@+id/tvDateTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="22nd Oct, 09:28 PM"
                android:textStyle="bold"
                android:textColor="@color/txy_clr"
                android:textSize="14sp"
                android:layout_alignParentStart="true" />

        </RelativeLayout>


        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp">


            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/tvAmountRed"
                android:text="Transaction Successful with long description that can wrap to next line without disturbing the red amount position"
                android:textColor="@color/txy_clr"
                android:textSize="14sp"
                android:lineSpacingExtra="2dp"
                android:maxLines="2" />


            <TextView
                android:id="@+id/tvAmountRed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_marginRight="100dp"
                android:layout_alignTop="@+id/tvDescription"
                android:text="Rs. 5"
                android:textColor="@color/red"
                android:textStyle="bold"
                android:textSize="15sp"
                android:visibility="visible" />

            <TextView
                android:id="@+id/tvAmountGreen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_alignTop="@+id/tvDescription"
                android:text="Rs. 5"
                android:textColor="@color/green"
                android:textStyle="bold"
                android:textSize="15sp"
                android:visibility="visible" />

        </RelativeLayout>


        <TextView
            android:id="@+id/tvBalance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Bal. Rs. 0"
            android:textColor="@color/green"
            android:textSize="13sp"
            android:paddingVertical="4dp"
            android:paddingHorizontal="10dp"
            android:background="@drawable/bg_balance_green"
            android:layout_gravity="start" />
    </LinearLayout>
</androidx.cardview.widget.CardView>