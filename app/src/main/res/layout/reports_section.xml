<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="16dp"
    android:paddingBottom="16dp"
    android:background="@color/white">

    <LinearLayout
        android:id="@+id/topIconRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp">


        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">


            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp">


                <ImageView
                    android:id="@+id/ic_sms_background"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/sms"
                    android:contentDescription="SMS Background"
                    android:tint="@color/light_gray" />


                <ImageView
                    android:id="@+id/ic_sms_overlay"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/clrsms"
                android:contentDescription="SMS Overlay"
                android:layout_gravity="bottom|end"
                android:visibility="gone" />

            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SMS"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:textColor="@color/light_gray" />
        </LinearLayout>


        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">


            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp">


                <ImageView
                    android:id="@+id/ic_whatsapp_background"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/whatsapp"
                    android:contentDescription="WhatsApp Background"
                    android:tint="@color/light_gray" />


                <ImageView
                    android:id="@+id/ic_whatsapp_overlay"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/clrwhatsapp"
                android:contentDescription="WhatsApp Overlay"
                android:layout_gravity="bottom|end"
                android:visibility="gone" />

            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WhatsApp"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:textColor="@color/light_gray" />
        </LinearLayout>


        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <ImageView
                android:id="@+id/ic_reports"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/pdf_outline_bg"
                android:contentDescription="Reports"
                android:padding="4dp"
                android:src="@drawable/pdf"
                android:tint="@color/red"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reports"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:textColor="@color/tint_clr"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>


    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/seperator"
        app:layout_constraintTop_toBottomOf="@id/topIconRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp" />


    <LinearLayout
        android:id="@+id/bottomLabelRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"
        android:paddingLeft="12dp"
        android:paddingRight="12dp">

        <TextView
            android:id="@+id/label_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Date"
            android:textSize="14sp"
            android:textColor="@color/txy_clr" />

        <TextView
            android:id="@+id/label_maine_diye"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Maine diye"
            android:textSize="14sp"
            android:textColor="@color/txy_clr" />

        <TextView
            android:id="@+id/label_maine_liye"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:text="Maine Liye"
            android:textSize="14sp"
            android:textColor="@color/txy_clr" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>