<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:layout_marginBottom="70dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:background="@color/base_color"
                android:gravity="center_vertical">


                <TextView
                    android:id="@+id/tvDropdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Easy Udhar"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/white" />


                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />


                <ImageView
                    android:id="@+id/ivLock"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/lock"
                    android:visibility="gone"
                    android:tint="@color/black" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@color/base_color">


                <androidx.cardview.widget.CardView
                    android:id="@+id/cardShowBalance"
                    android:layout_width="300dp"
                    android:layout_height="40dp"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="6dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:clickable="false"
                        android:focusable="false">


                        <TextView
                            android:id="@+id/txtShowBalance"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Show Balance"
                            android:textColor="#FF5722"
                            android:textStyle="bold"
                            android:textSize="18sp" />


                        <View
                            android:layout_width="1dp"
                            android:layout_height="30dp"
                            android:background="#33000000" />


                        <ImageView
                            android:id="@+id/arrowIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:padding="4dp"
                            android:src="@drawable/arrow_right"
                            android:tint="#FF5722" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>


            <LinearLayout
                android:id="@+id/balanceCardsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/base_color"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:visibility="gone">


                <LinearLayout
                    android:id="@+id/red_card"
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_weight="1"
                    android:background="@drawable/red_card_normal"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginEnd="8dp"
                    android:padding="10dp"
                    android:elevation="2dp"
                    android:clipToOutline="true"
                    android:clickable="true">

                    <ImageView
                        android:id="@+id/red_icon"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/down"
                        android:tint="@color/tint_red_selector"
                        android:layout_marginEnd="8dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/red_amount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rs. 0"
                            android:textColor="@color/text_color_selector"
                            android:textStyle="bold"
                            android:textSize="18sp" />

                        <TextView
                            android:id="@+id/red_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Maine lene hain"
                            android:textColor="@color/text_color_selector"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>


                <LinearLayout
                    android:id="@+id/green_card"
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_weight="1"
                    android:background="@drawable/green_card_normal"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginStart="8dp"
                    android:padding="10dp"
                    android:elevation="2dp"
                    android:clipToOutline="true"
                    android:clickable="true">

                    <ImageView
                        android:id="@+id/green_icon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/up"
                        android:tint="@color/tint_green_selector"
                        android:layout_marginEnd="8dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/green_amount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rs. 0"
                            android:textColor="@color/text_color_green_selector"
                            android:textStyle="bold"
                            android:textSize="18sp" />

                        <TextView
                            android:id="@+id/green_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Maine dene hain"
                            android:textColor="@color/text_color_green_selector"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/shape_design"/>


            <LinearLayout
                android:id="@+id/search_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:background="@color/white"
                android:visibility="gone">


                <LinearLayout
                    android:id="@+id/searchContainer"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginLeft="10dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:background="@drawable/search_bg">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/search"
                        android:tint="@color/tint_clr" />

                    <EditText
                        android:id="@+id/searchEditText"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Search Customer"
                        android:textSize="16sp"
                        android:textColor="@color/black"
                        android:textColorHint="@color/tint_clr"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:singleLine="true" />

                    <ImageView
                        android:id="@+id/clearSearch"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/close"
                        android:tint="@color/tint_clr"
                        android:visibility="invisible" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/btnfilter"
                    android:layout_width="48dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:src="@drawable/filter"
                    android:contentDescription="Filter Button" />


                <TextView
                    android:id="@+id/btnPdf"
                    android:layout_width="48dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="PDF"
                    android:textStyle="bold"
                    android:layout_marginRight="10dp"
                    android:textColor="@color/tint_clr"
                    android:background="@drawable/pdf_button_bg" />
            </LinearLayout>


            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerCustomers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="400dp"
                android:visibility="gone"
                android:padding="8dp"
                tools:listitem="@layout/item_dashboard" />


            <LinearLayout
                android:id="@+id/middle_section"
                android:layout_width="match_parent"
                android:layout_height="400dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@color/white">

                <ImageView
                    android:id="@+id/ivIllustration"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:src="@drawable/add_contact"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Customer add karein aur unka hisaab kitaab rakhna shuru karein"
                    android:textSize="14sp"
                    android:textColor="@color/tint_clr"
                    android:gravity="center"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginBottom="8dp" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/down_arrow"
                    android:tint="@color/tint_clr" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>


    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:elevation="10dp" />


    <ImageView
        android:id="@+id/btn_add_contact"
        android:layout_width="55dp"
        android:layout_height="55dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="80dp"
        android:src="@drawable/add2"
        android:background="@drawable/floating_bg"
        android:padding="12dp"
        android:elevation="10dp"
        android:contentDescription="Floating Action"
        android:clickable="true"
        android:focusable="true" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bottom_nav"
        app:labelVisibilityMode="labeled"
        android:paddingTop="17dp"
        app:itemIconTint="@color/bottom_nav_colors"
        app:itemTextColor="@color/bottom_nav_colors"
        app:menu="@menu/bottom_nav_menu"
        android:elevation="8dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>